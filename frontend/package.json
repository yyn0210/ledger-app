{
  "name": "ledger-app-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix",
    "format": "prettier --write src/",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lighthouse": "lighthouse http://localhost:5173 --output html --output-path ./performance/lighthouse-report.html",
    "vitals": "node scripts/collect-vitals.js"
  },
  "dependencies": {
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@vicons/antd": "^0.13.0",
    "@vicons/ionicons5": "^0.13.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/test-utils": "^2.4.6",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^29.0.1",
    "lodash-es": "^4.17.23",
    "naive-ui": "^2.44.1",
    "pinia": "^3.0.4",
    "prettier": "^3.8.1",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vfonts": "^0.0.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.1",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4"
  }
}
